{
  "expo": {
    "name": "TradeIQ",
    "slug": "tradeiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/imports/brand-icon.png",
    "scheme": "dra",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "src/imports/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/imports/brand-icon.png",
        "backgroundColor": "#060810"
      }
    },
    "splash": {
      "image": "./src/imports/brand-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060810"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
